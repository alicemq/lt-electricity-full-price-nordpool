# Frontend environment — safe placeholders only.
# Copy to .env or .env.production locally. Do NOT commit live values.
#
# Vite exposes only VITE_* variables to the client bundle.

VITE_API_BASE_URL=/api/v1

# Optional: canonical site URL override (defaults to package.json homepage)
# VITE_BASE_URL=https://elektra.teletigras.lt

# Optional: Google Search Console HTML meta verification code
# Injected at build time into index.html when set.
# VITE_GOOGLE_SITE_VERIFICATION=your_verification_code
