# Example environment configuration — safe placeholders only.
# Copy to .env, .env.development, or .env.production and fill in real values locally.
# Do NOT commit files containing production secrets or database passwords.
#
# See deploy/local.env.example for local port overrides used by smoke scripts.

# Runtime
NODE_ENV=development

# Frontend
VITE_API_BASE_URL=/api/v1
FRONTEND_URL=http://localhost:5173
FRONTEND_COMMAND=npm run dev -- --host 0.0.0.0

# Backend
BACKEND_COMMAND=npm run dev
ELERING_API_URL=https://dashboard.elering.ee/api/nps/price
DATABASE_URL=postgresql://electricity_user:CHANGE_ME@db:5432/electricity_prices
ADMIN_API_TOKEN=CHANGE_ME

# Web Push (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# Database (development only — use platform secrets in production)
# scripts/dev.sh auto-generates a strong local password when value is CHANGE_ME
POSTGRES_DB=electricity_prices
POSTGRES_USER=electricity_user
POSTGRES_PASSWORD=CHANGE_ME
